{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/test-image-ui/layer_contract.schema.json",
  "title": "Spec Driven Layer Contract",
  "type": "object",
  "required": ["version", "contract_id", "board_image", "canvas", "asset_cells"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string"
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "primary_asset_id": {
      "type": "string"
    },
    "board_image": {
      "type": "string",
      "description": "Path to the generated production board image, relative to this JSON file or absolute."
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "split_x": {
      "type": "integer",
      "minimum": 1
    },
    "asset_sheet_detection": {
      "$ref": "#/$defs/asset_sheet_detection"
    },
    "diagnostic_crops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic_crop"
      }
    },
    "asset_cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/asset_cell"
      }
    },
    "text_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/text_node"
      }
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation_check"
      }
    },
    "manual_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/manual_check"
      }
    },
    "rough_reconstruction": {
      "$ref": "#/$defs/rough_reconstruction"
    },
    "interpretation": {
      "type": "string"
    },
    "verdict": {
      "type": "string"
    }
  },
  "$defs": {
    "bbox": {
      "type": "array",
      "prefixItems": [
        {
          "type": "integer"
        },
        {
          "type": "integer"
        },
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "diagnostic_crop": {
      "type": "object",
      "required": ["id", "bbox"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "asset_cell": {
      "type": "object",
      "required": ["id", "role", "bbox"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "parent_layer": {
          "type": "string"
        },
        "children_excluded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transparent": {
          "type": "boolean"
        },
        "forbid_text": {
          "type": "boolean"
        },
        "scale_mode": {
          "type": "string",
          "enum": ["contain", "cover", "stretch", "nine_slice", "reference_only"]
        },
        "nine_slice_candidate": {
          "type": "boolean"
        },
        "bbox_detection_hint": {
          "type": "string",
          "enum": ["trim_saturated_left_edge_then_foreground"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "asset_sheet_detection": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": ["foreground_safe_bbox", "grid_cell_foreground_safe_bbox"]
        },
        "padding": {
          "type": "integer",
          "minimum": 0
        },
        "threshold": {
          "type": "number",
          "minimum": 0
        },
        "min_component_area": {
          "type": "integer",
          "minimum": 1
        },
        "drop_border_artifacts": {
          "type": "boolean"
        },
        "border_artifact_width_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "border_artifact_height_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "border_artifact_area_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "text_node": {
      "type": "object",
      "required": ["id", "text"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "validation_check": {
      "type": "object",
      "required": ["id", "asset_id", "metric", "op", "value"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "asset_id": {
          "type": "string"
        },
        "metric": {
          "type": "string",
          "enum": [
            "green_ratio",
            "red_ratio_hsv",
            "dark_text_like_ratio",
            "gold_ratio",
            "cream_ratio",
            "transparent_ratio",
            "corner_alpha_max",
            "label_artifact_score",
            "label_artifact_ratio",
            "label_artifact_candidate_count"
          ]
        },
        "op": {
          "type": "string",
          "enum": ["<", "<=", ">", ">=", "==", "!="]
        },
        "value": {
          "type": "number"
        }
      }
    },
    "manual_check": {
      "type": "object",
      "required": ["id", "status"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pass", "passed", "pending", "fail", "failed"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "rough_reconstruction": {
      "type": "object",
      "required": ["canvas", "layers"],
      "additionalProperties": true,
      "properties": {
        "canvas": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "asset_id", "rect"],
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "asset_id": {
                "type": "string"
              },
              "rect": {
                "$ref": "#/$defs/bbox"
              },
              "scale_mode": {
                "type": "string"
              }
            }
          }
        },
        "text_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text", "rect"],
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "rect": {
                "$ref": "#/$defs/bbox"
              },
              "font_size": {
                "type": "integer",
                "minimum": 1
              },
              "fill": {
                "type": "string"
              },
              "stroke_fill": {
                "type": "string"
              },
              "stroke_width": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
